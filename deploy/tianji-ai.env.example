# Existing AI service
DEEPSEEK_API_KEY=replace-with-server-secret
DEEPSEEK_MODEL=deepseek-v4-flash
TIANJI_AI_PORT=8788
TIANJI_AI_PER_IP_HOUR=20
TIANJI_AI_GLOBAL_DAY=200

# Public origins and allowed reverse-proxy hosts
TIANJI_PUBLIC_ORIGIN=https://daofainsight.com
TIANJI_ALLOWED_HOSTS=daofainsight.com,www.daofainsight.com,tianji.47-86-31-98.sslip.io,127.0.0.1,localhost

# China-first one-time memberships. Checkout stays disabled while the provider is china_pending.
TIANJI_PAYMENT_PROVIDER=china_pending
TIANJI_PRICE_30D_CNY=¥39
TIANJI_PRICE_365D_CNY=¥299
TIANJI_AI_PRO_DAY=100

# Add approved Alipay or WeChat Pay merchant credentials only on the server after
# the legal entity, payment product and operating domain have passed review.
# Never place merchant private keys, API v3 keys or platform certificates in Git.

# Membership recovery email. Brevo SMTP example; use the SMTP key, not the Brevo login password.
TIANJI_RECOVERY_SECRET=replace-with-a-long-random-server-secret
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=replace-with-brevo-smtp-login
SMTP_PASSWORD=replace-with-brevo-smtp-key
SMTP_FROM=DAOFA <support@daofainsight.com>
SMTP_STARTTLS=1
