# Existing AI service
DEEPSEEK_API_KEY=replace-with-server-secret
DEEPSEEK_MODEL=deepseek-v4-flash
TIANJI_AI_PORT=8788
TIANJI_AI_PER_IP_HOUR=20
TIANJI_AI_GLOBAL_DAY=200

# Phone accounts and one-day no-sign-in trial
TIANJI_AUTH_SECRET=replace-with-a-long-random-server-secret
TIANJI_AUTH_SESSION_DAYS=30
TIANJI_TRIAL_HOURS=24
TIANJI_WELCOME_TRIAL_DAYS=3
TIANJI_TRIAL_MARKER_DAYS=365
TIANJI_OTP_SECONDS=300
TIANJI_OWNER_PHONE=17606669594

# Reuse the existing Supabase Auth -> Aliyun SMS hook.
TIANJI_SMS_PROVIDER=supabase
TIANJI_SUPABASE_URL=https://your-project.supabase.co
TIANJI_SUPABASE_ANON_KEY=replace-with-project-anon-key

# Optional direct Aliyun fallback. Keep these values server-side only.
ALIYUN_PNVS_ACCESS_KEY_ID=replace-with-least-privilege-access-key-id
ALIYUN_PNVS_ACCESS_KEY_SECRET=replace-with-least-privilege-access-key-secret
ALIYUN_PNVS_SIGN_NAME=replace-with-approved-sign-name
ALIYUN_PNVS_TEMPLATE_CODE=replace-with-approved-template-code

# Public origins and allowed reverse-proxy hosts
TIANJI_PUBLIC_ORIGIN=https://daofainsight.com
TIANJI_ALLOWED_HOSTS=daofainsight.com,www.daofainsight.com,tianji.47-86-31-98.sslip.io,127.0.0.1,localhost

# Legacy automatic checkout remains disabled. The website's manual-review flow is
# account-bound; compliant merchant payment codes are uploaded by the owner and
# stored under the service StateDirectory rather than in this file or Git.
TIANJI_PAYMENT_PROVIDER=apple_iap_pending
TIANJI_WEB_CHECKOUT_ENABLED=0
TIANJI_PRICE_30D_CNY=39
TIANJI_PRICE_365D_CNY=299
TIANJI_AI_PRO_DAY=100

# StoreKit transaction-verification credentials belong only on the server after
# Apple Developer and App Store Connect setup is complete. Never commit secrets.

# Membership recovery email. Brevo SMTP example; use the SMTP key, not the Brevo login password.
TIANJI_RECOVERY_SECRET=replace-with-a-long-random-server-secret
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=replace-with-brevo-smtp-login
SMTP_PASSWORD=replace-with-brevo-smtp-key
SMTP_FROM=DAOFA <support@daofainsight.com>
SMTP_STARTTLS=1
